# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# Option A: discrete vars (docker-compose / local Postgres)
POSTGRES_USER=quickeee
POSTGRES_PASSWORD=quickeee_secret
POSTGRES_DB=quickeee_visual
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Option B: a single managed URL (Neon/Render/Supabase). Overrides POSTGRES_* if set.
# DATABASE_URL_OVERRIDE=postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/db?sslmode=require

# ---- AI Vision (Step 6 verification) ----
AI_PROVIDER=anthropic            # anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
MATCH_ACCEPTANCE_THRESHOLD=90    # only accept matches at/above this score

# ---- Quickeee source (Step 2) ----
QUICKEEE_BASE_URL=https://quickeee.com
QUICKEEE_API_BASE=https://api.quickeee.com
QUICKEEE_API_TOKEN=              # optional partner API token; not needed for live mode
QUICKEEE_LIVE=true               # capture the site's anon token + call the real catalog API (no keys)
QUICKEEE_DEFAULT_PINCODE=400049  # default store the site resolves (Mumbai)

# ---- Reverse image / visual search (Steps 4-5) ----
VISUAL_SEARCH_PROVIDER=serpapi   # serpapi | bing | playwright
SERPAPI_KEY=                     # https://serpapi.com (Google Lens + Google Shopping)
BING_VISUAL_SEARCH_KEY=          # Azure Bing Visual Search (fallback)

# ---- Scraping / runtime ----
MOCK_MODE=true                   # true = full offline demo with fixtures
HEADLESS=true
MAX_COMPETITOR_CANDIDATES=12
IMAGE_STORE_DIR=./data/images
